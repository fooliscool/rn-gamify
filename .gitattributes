# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf

# Config files
.eslintrc text eol=lf
.prettierrc text eol=lf
tsconfig.json text eol=lf
jest.config.js text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary