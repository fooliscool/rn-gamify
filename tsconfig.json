{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "jsx": "react-native",
    "types": ["jest", "react", "react-native"],
    "baseUrl": ".",
    "paths": {
      "@rn-monorepo/common": ["../../packages/common/src"]
    }
  },
  "include": ["**/*.tsx", "**/*.ts"],
  "exclude": ["node_modules", "dist", "android", "ios"]
}
